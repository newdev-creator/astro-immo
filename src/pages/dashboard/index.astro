---
import Dashboard from "@layouts/Dashboard.astro";
const user = Astro.locals.user!;
---

<Dashboard>
    <h2 class="text-2xl font-bold mb-6">Bonjour, {user.nom} 👋</h2>

    <div class="grid grid-cols-3 gap-4">
        <div class="card bg-base-100 shadow">
            <div class="card-body">
                <h3 class="card-title text-sm text-base-content/60">
                    Biens actifs
                </h3>
                <p class="text-3xl font-bold">—</p>
            </div>
        </div>
        <div class="card bg-base-100 shadow">
            <div class="card-body">
                <h3 class="card-title text-sm text-base-content/60">Clients</h3>
                <p class="text-3xl font-bold">—</p>
            </div>
        </div>
        <div class="card bg-base-100 shadow">
            <div class="card-body">
                <h3 class="card-title text-sm text-base-content/60">
                    Ventes ce mois
                </h3>
                <p class="text-3xl font-bold">—</p>
            </div>
        </div>
    </div>
</Dashboard>
