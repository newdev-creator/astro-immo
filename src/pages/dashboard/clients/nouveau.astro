---
import Dashboard from "@layouts/Dashboard.astro";
import { apiFetch } from "@lib/api";

if (Astro.request.method === "POST") {
    const form = await Astro.request.formData();
    const res = await apiFetch("/api/clients/", Astro.request, {
        method: "POST",
        body: JSON.stringify({
            nom: form.get("nom"),
            prenom: form.get("prenom"),
            email: form.get("email") || null,
            telephone: form.get("telephone") || null,
            budget: form.get("budget")
                ? parseFloat(form.get("budget") as string)
                : null,
        }),
    });
    if (res.ok) return Astro.redirect("/dashboard/clients");
}
---

<Dashboard>
    <div class="max-w-2xl">
        <h2 class="text-2xl font-bold mb-6">Nouveau client</h2>
        <form
            method="POST"
            class="card bg-base-100 shadow p-6 flex flex-col gap-4"
        >
            <div class="grid grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label"
                        ><span class="label-text">Prénom *</span></label
                    >
                    <input
                        name="prenom"
                        type="text"
                        class="input input-bordered"
                        required
                    />
                </div>
                <div class="form-control">
                    <label class="label"
                        ><span class="label-text">Nom *</span></label
                    >
                    <input
                        name="nom"
                        type="text"
                        class="input input-bordered"
                        required
                    />
                </div>
            </div>
            <div class="form-control">
                <label class="label"
                    ><span class="label-text">Email</span></label
                >
                <input name="email" type="email" class="input input-bordered" />
            </div>
            <div class="form-control">
                <label class="label"
                    ><span class="label-text">Téléphone</span></label
                >
                <input
                    name="telephone"
                    type="tel"
                    class="input input-bordered"
                />
            </div>
            <div class="form-control">
                <label class="label"
                    ><span class="label-text">Budget (€)</span></label
                >
                <input
                    name="budget"
                    type="number"
                    step="0.01"
                    class="input input-bordered"
                />
            </div>
            <div class="flex gap-2 justify-end mt-2">
                <a href="/dashboard/clients" class="btn btn-ghost">Annuler</a>
                <button type="submit" class="btn btn-primary"
                    >Créer le client</button
                >
            </div>
        </form>
    </div>
</Dashboard>
