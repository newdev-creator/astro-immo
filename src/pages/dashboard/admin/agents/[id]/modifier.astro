---
import Dashboard from "@layouts/Dashboard.astro";
import { apiFetch } from "@lib/api";

const { id } = Astro.params;
let error = "";

if (Astro.request.method === "POST") {
    const form = await Astro.request.formData();
    const action = form.get("_action");

    if (action === "delete") {
        const res = await apiFetch(`/api/agents/${id}`, Astro.request, {
            method: "DELETE",
        });
        if (res.ok) return Astro.redirect("/dashboard/admin/agents");
        const err = await res.json();
        error = err.detail ?? "Erreur lors de la suppression";
    } else {
        const password = form.get("password") as string;
        const res = await apiFetch(`/api/agents/${id}`, Astro.request, {
            method: "PUT",
            body: JSON.stringify({
                nom: form.get("nom"),
                prenom: form.get("prenom"),
                email: form.get("email"),
                password: password || null,
            }),
        });
        if (res.ok) return Astro.redirect("/dashboard/admin/agents");
        const err = await res.json();
        error = err.detail ?? "Erreur lors de la modification";
    }
}

const res = await apiFetch(`/api/agents/${id}`, Astro.request);
if (!res.ok) return Astro.redirect("/dashboard/admin/agents");
const agent = await res.json();
---

<Dashboard>
    <div class="max-w-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold">Modifier l'agent</h2>
            <form method="POST">
                <input type="hidden" name="_action" value="delete" />
                <button
                    type="submit"
                    class="btn btn-error btn-sm"
                    onclick="return confirm('Supprimer cet agent ?')"
                >
                    Supprimer
                </button>
            </form>
        </div>

        {error && <div class="alert alert-error mb-4">{error}</div>}

        <form
            method="POST"
            class="card bg-base-100 shadow p-6 flex flex-col gap-4"
        >
            <div class="grid grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label"
                        ><span class="label-text">Prénom *</span></label
                    >
                    <input
                        name="prenom"
                        type="text"
                        class="input input-bordered"
                        value={agent.prenom}
                        required
                    />
                </div>
                <div class="form-control">
                    <label class="label"
                        ><span class="label-text">Nom *</span></label
                    >
                    <input
                        name="nom"
                        type="text"
                        class="input input-bordered"
                        value={agent.nom}
                        required
                    />
                </div>
            </div>
            <div class="form-control">
                <label class="label"
                    ><span class="label-text">Email *</span></label
                >
                <input
                    name="email"
                    type="email"
                    class="input input-bordered"
                    value={agent.email}
                    required
                />
            </div>
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Nouveau mot de passe</span>
                    <span class="label-text-alt"
                        >Laisser vide pour ne pas changer</span
                    >
                </label>
                <input
                    name="password"
                    type="password"
                    class="input input-bordered"
                />
            </div>
            <div class="flex gap-2 justify-end mt-2">
                <a href="/dashboard/admin/agents" class="btn btn-ghost"
                    >Annuler</a
                >
                <button type="submit" class="btn btn-primary"
                    >Enregistrer</button
                >
            </div>
        </form>
    </div>
</Dashboard>
